# PostgreSQL — get both strings from Supabase Dashboard → Connect
#
# IMPORTANT:
# - Paste ONLY the URL in Vercel (no quotes, no "DATABASE_URL=" prefix)
# - If your password has @ : / # ? & encode them (e.g. @ → %40)
# - Replace REGION with your pooler region (e.g. ap-southeast-1)

# App runtime on Vercel — Transaction pooler, port 6543
DATABASE_URL=postgresql://postgres.mpuboebxkugbobspodwd:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

# Migrations / prisma migrate deploy — Session pooler, port 5432
DIRECT_URL=postgresql://postgres.mpuboebxkugbobspodwd:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Supabase (Settings → API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://mpuboebxkugbobspodwd.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy projects may use anon JWT instead:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NVIDIA NIM (Job Finder Agent) — get a key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-...
# Optional overrides:
# NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct
