# PostgreSQL (Supabase connection pooler or direct)
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# Supabase (from Connect panel or Settings → API Keys)
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# Legacy projects may use anon JWT instead:
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Server-only — Phase 4+ (Settings → API Keys → Secret key)
# SUPABASE_SECRET_KEY="sb_secret_..."
# Legacy name also supported:
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
