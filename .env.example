# Vercel runtime — Transaction pooler (port 6543)
DATABASE_URL=postgresql://postgres.mpuboebxkugbobspodwd:YOUR_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# Migrations at build time — Direct connection (avoids session pooler max-client limit)
DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.mpuboebxkugbobspodwd.supabase.co:5432/postgres

# Optional — only if auto-conversion picks the wrong pooler region
# SUPABASE_POOLER_HOST=aws-1-ap-southeast-2.pooler.supabase.com

NEXT_PUBLIC_SUPABASE_URL=https://mpuboebxkugbobspodwd.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Supabase Auth: set Site URL to NEXT_PUBLIC_APP_URL and add redirect:
#   https://your-app.vercel.app/auth/callback
# If confirmation emails never arrive, disable "Confirm email" under Auth → Providers → Email.

# Server-only — Supabase Dashboard → Settings → API → service_role (optional; seed no longer needs this)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Demo mode — cookie login without Supabase email; auto-seed fake listings on Vercel build
ENABLE_DEMO_BYPASS=true
SEED_DEMO_DATA=true
