# PostgreSQL — Supabase Dashboard → Connect → Session pooler (port 5432)
#
# Vercel: add ONE variable named DATABASE_URL (Production + Preview)
# Paste ONLY the URL — no quotes, no "DATABASE_URL=" prefix
# URL-encode special password chars: @ → %40  # → %23  : → %3A

DATABASE_URL=postgresql://postgres.mpuboebxkugbobspodwd:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Supabase (Settings → API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://mpuboebxkugbobspodwd.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# App — your Vercel production URL
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# NVIDIA NIM (Job Finder Agent) — optional
# NVIDIA_API_KEY=nvapi-...
