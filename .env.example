# PostgreSQL — Supabase Dashboard → Connect
#
# Vercel: set ONLY DATABASE_URL (DIRECT_URL is auto-derived at build time)
# Paste ONLY the URL value — no quotes, no "DATABASE_URL=" prefix
# URL-encode special password chars: @ → %40  # → %23  : → %3A

# Recommended for Vercel — Transaction pooler, port 6543
DATABASE_URL=postgresql://postgres.mpuboebxkugbobspodwd:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

# Optional — only if you want a separate migration URL (port 5432)
# DIRECT_URL=postgresql://postgres.mpuboebxkugbobspodwd:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Supabase (Settings → API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://mpuboebxkugbobspodwd.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NVIDIA NIM (Job Finder Agent) — optional
# NVIDIA_API_KEY=nvapi-...
